@startuml ActivityDiagram
!theme plain
title 智慧图书馆座位预约系统 — 座位预约活动图

start

:用户打开系统;

if (是否已登录?) then (否)
  :跳转登录页;
  partition "注册/登录" {
    if (已有账号?) then (是)
      :输入用户名和密码;
      :调用登录接口;
      if (登录成功?) then (是)
        :获取Token并存储;
      else (否)
        :提示错误信息;
        stop
      endif
    else (否)
      :填写注册信息;
      :调用注册接口;
      if (注册成功?) then (是)
        :自动登录并获取Token;
      else (否)
        :提示错误信息;
        stop
      endif
    endif
  }
else (是)
  :验证Token有效性;
endif

:进入首页;

partition "浏览座位" {
  :查看楼层空余座位概览;
  :选择楼层;
  :查看座位地图;
  :按类型筛选座位\n(靠窗/电源/静音区);
}

partition "预约座位" {
  :点击目标座位;
  :选择预约时间段\n(08:00-22:00);
  :系统校验时间段合法性;
  if (时间段合法?) then (否)
    :提示错误原因\n(时间冲突/跨闭馆时间/时长不足);
    stop
  else (是)
    :确认预约信息;
    :调用预约接口;
    if (预约成功?) then (是)
      :推送预约成功通知;
      :更新座位状态为已占;
    else (否)
      :提示预约失败原因;
      stop
    endif
  endif
}

partition "签到" {
  :到达图书馆;
  :进入我的预约;
  :点击签到按钮;
  if (预约状态为待签到?) then (是)
    :调用签到接口;
    :记录签到时间;
    :推送签到成功通知;
    :预约状态变更为使用中;
  else (否)
    :提示无法签到;
    stop
  endif
}

partition "签退" {
  :学习结束;
  :点击签退按钮;
  if (预约状态为使用中?) then (是)
    :调用签退接口;
    :记录签退时间;
    :计算本次学习时长;
    :累计至用户总学习时长;
    :推送签退成功通知;
    :预约状态变更为已完成;
    :释放座位;
  else (否)
    :提示无法签退;
    stop
  endif
}

:流程结束;
stop

@enduml
